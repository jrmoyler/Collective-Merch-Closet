# Required for the AI fitting room (/api/try-on).
# The name is matched case-insensitively (openai_api_key works too), and
# surrounding quotes/whitespace are stripped from the value automatically.
OPENAI_API_KEY=

# Optional overrides.
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
# OPENAI_API_BASE_URL=https://api.openai.com/v1
