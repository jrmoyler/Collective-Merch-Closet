# The AI fitting room (/api/try-on) needs ONE of these keys. When both are
# set, the Agnes key wins (its image API is free) — force a choice with
# TRY_ON_PROVIDER=agnes or TRY_ON_PROVIDER=openai.
# Names are matched case-insensitively (agnes_api_key works too), and
# surrounding quotes/whitespace are stripped from the value automatically.
AGNES_API_KEY=
OPENAI_API_KEY=

# Optional overrides.
# TRY_ON_PROVIDER=agnes
# AGNES_IMAGE_MODEL=agnes-image-2.1-flash
# AGNES_IMAGE_SIZE=1024x1536
# AGNES_API_BASE_URL=https://apihub.agnes-ai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
# OPENAI_API_BASE_URL=https://api.openai.com/v1
